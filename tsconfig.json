{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "shared/src/**/*.ts",
    "kyan-signatures/src/**/*.ts",
    "kyan-trading/src/**/*.ts",
    "kyan-websocket/src/**/*.ts",
    "kyan-account/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "examples"]
}
