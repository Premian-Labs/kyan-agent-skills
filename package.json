{
  "name": "kyan-skills",
  "version": "1.0.0",
  "description": "Agent skills for Kyan.blue derivatives trading exchange",
  "private": true,
  "workspaces": [
    "shared",
    "kyan-signatures",
    "kyan-trading",
    "kyan-websocket",
    "kyan-account",
    "kyan-mcp"
  ],
  "scripts": {
    "test": "vitest run --exclude integration",
    "test:unit": "vitest run --exclude integration",
    "test:integration": "vitest run integration/",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sanitize": "bash scripts/pre-commit-sanitize"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "viem": "^2.23.0"
  }
}
