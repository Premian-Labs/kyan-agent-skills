# Kyan Integration Test Environment Variables
# Copy to .env and fill in your values. Never commit .env!

# Required: API key from Premia team (Discord, email, or premia.io)
KYAN_API_KEY=

# Required for signing tests: Arbitrum Sepolia testnet wallet private key (no 0x prefix)
WALLET_PRIVATE_KEY=

# Required for signing tests: ClearingHouseProxy contract address on Arbitrum Sepolia
# Testnet default: 0x746EE6b2689D56d9D593BC1bB733b48BfD4908D0
CLEARING_HOUSE_PROXY=0x746EE6b2689D56d9D593BC1bB733b48BfD4908D0

# Optional: Override API base URL (defaults to https://staging.kyan.sh)
KYAN_BASE_URL=
